{
    "name": "versepc",
    "version": "1.3.0",
    "description": "VersePC - Minecraft Launcher",
    "author": {
        "name": "豆杰",
        "email": "versepc@example.com"
    },
    "license": "VPSVL-1.0",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "obfuscate": "node obfuscate-activation.js",
        "build": "npm run obfuscate && node generate-integrity.js && electron-builder --win --linux --mac --publish never",
        "build:win": "npm run obfuscate && node generate-integrity.js && electron-builder --win --publish never",
        "build:win:test": "cross-env ENABLE_AI=true node obfuscate-activation.js && cross-env ENABLE_AI=true node generate-integrity.js && cross-env ENABLE_AI=true electron-builder --win --publish never",
        "build:win:release": "cross-env ENABLE_AI=false node obfuscate-activation.js && cross-env ENABLE_AI=false node generate-integrity.js && cross-env ENABLE_AI=false electron-builder --win --publish never",
        "build:linux": "npm run obfuscate && electron-builder --linux --publish never",
        "build:linux:test": "cross-env ENABLE_AI=true npm run obfuscate && electron-builder --linux --publish never",
        "build:linux:release": "cross-env ENABLE_AI=false npm run obfuscate && electron-builder --linux --publish never",
        "build:mac": "npm run obfuscate && node generate-integrity.js && electron-builder --mac --publish never",
        "build:mac:test": "cross-env ENABLE_AI=true npm run obfuscate && node generate-integrity.js && electron-builder --mac --publish never",
        "build:mac:release": "cross-env ENABLE_AI=false npm run obfuscate && node generate-integrity.js && electron-builder --mac --publish never",
        "build:dir": "npm run obfuscate && electron-builder --win --dir",
        "build:installer": "npm run obfuscate && electron-builder --win --config.nsis --publish never",
        "build:publish": "npm run obfuscate && electron-builder --win --linux --mac --publish always",
        "build:clean": "node -e \"const{execSync}=require('child_process');execSync('npm run build:win',{stdio:'inherit'})\""
    },
    "dependencies": {
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "adm-zip": "^0.5.17",
        "electron-updater": "^6.8.3",
        "monaco-editor": "^0.55.1",
        "recycle-bin": "^0.1.3",
        "sharp": "^0.34.5",
        "ws": "^8.20.0"
    },
    "build": {
        "appId": "com.versepc.launcher",
        "productName": "VersePC",
        "icon": "img/icon.png",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "server.js",
            "neoforge-processor.js",
            "forge-processor.js",
            "forge-installer.js",
            "sse-server.js",
            "agent-engine.js",
            "agent-worker.js",
            "activation.obfuscated.js",
            "ai-config.js",
            "plugin-manager.js",
            "preload.cjs",
            "editor-preload.cjs",
            "index.html",
            "editor.html",
            "file-browser.html",
            "assets/**/*",
            "css/**/*",
            "js/**/*",
            "img/**/*",
            "images/**/*",
            "fonts/**/*",
            "scripts/**/*",
            "resources/**/*",
            "plugins/**/*",
            "node_modules/monaco-editor/**/*",
            "integrity.json",
            "ai-enabled.json",
            "package.json",
            "node_modules/adm-zip/**/*",
            "node_modules/ws/**/*",
            "node_modules/electron-updater/**/*",
            "node_modules/builder-util-runtime/**/*",
            "node_modules/lazy-val/**/*",
            "node_modules/fs-extra/**/*",
            "node_modules/jsonfile/**/*",
            "node_modules/universalify/**/*",
            "node_modules/semver/**/*",
            "node_modules/lru-cache/**/*",
            "node_modules/yallist/**/*",
            "node_modules/sharp/**/*",
            "node_modules/@img/**/*",
            "node_modules/detect-libc/**/*"
        ],
        "publish": {
            "provider": "github",
            "owner": "doujie081231",
            "repo": "versePc"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "icon": "img/icon.png",
            "category": "public.app-category.games",
            "artifactName": "VersePC-${version}-${arch}.${ext}"
        },
        "dmg": {
            "artifactName": "VersePC-${version}-${arch}.dmg",
            "contents": [
                {
                    "x": 130,
                    "y": 220
                },
                {
                    "x": 410,
                    "y": 220,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "img/icon.png",
            "category": "Game",
            "artifactName": "VersePC-${version}-${arch}.${ext}",
            "desktop": {
                "entry": "Name=VersePC\nComment=VersePC - Minecraft Launcher\nCategories=Game;"
            }
        },
        "portable": {
            "artifactName": "VersePC-${version}.exe",
            "requestExecutionLevel": "user"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "allowElevation": true,
            "installerLanguages": [
                "zh-CN"
            ],
            "language": 2052,
            "installerIcon": "img/icon.ico",
            "uninstallerIcon": "img/icon.ico",
            "installerHeaderIcon": "img/installer-header.bmp",
            "artifactName": "VersePC-Setup-${version}.exe",
            "deleteAppDataOnUninstall": false,
            "runAfterFinish": true,
            "createStartMenuShortcut": true,
            "shortcutName": "VersePC",
            "include": "installer/customInstall.nsh",
            "license": "installer/license.txt",
            "unicode": true,
            "differentialPackage": true,
            "warningsAsErrors": false,
            "menuCategory": "VersePC",
            "createDesktopShortcut": "always",
            "displayLanguageSelector": false,
            "packElevateHelper": true,
            "perMachine": false
        },
        "asar": true,
        "asarUnpack": [
            "node_modules/sharp/**/*",
            "node_modules/@img/**/*",
            "node_modules/canvas/**/*",
            "node_modules/detect-libc/**/*",
            "img/icon.ico",
            "img/icon.png",
            "resources/**/*"
        ],
        "releaseInfo": {
            "releaseNotes": "鏌ョ湅 GitHub Releases 鑾峰彇鏇存柊鏃ュ織锛歨ttps://github.com/doujie081231/versePc/releases"
        }
    },
    "devDependencies": {
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "cross-env": "^7.0.3",
        "electron": "^41.4.0",
        "electron-builder": "^26.8.1",
        "javascript-obfuscator": "^5.4.3",
        "png-to-ico": "^3.0.1"
    }
}
